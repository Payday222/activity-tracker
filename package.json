{
  "name": "activity-tracker",
  "version": "1.0.0",
  "description": "Cross platform activity tracker",
  "author": "Michal Kaliszuk",
  "main": "main.js",
  "scripts": {
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "20.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "chartjs-chart-treemap": "^3.1.0",
    "active-win": "^8.0.0"
  },
  "build": {
    "appId": "com.michal.activitytracker",
    "productName": "ActivityTracker",

    "npmRebuild": false,
    "nodeGypRebuild": false,

    "asarUnpack": [
      "node_modules/active-win/**"
    ],

    "extraResources": [
      {
        "from": "node_modules",
        "to": "node_modules"
      }
    ],

    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },

    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },

    "win": {
      "target": "nsis"
    }
  }
}
